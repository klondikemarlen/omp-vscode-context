{
  "name": "omp-vscode-context",
  "displayName": "Oh My Pi Context Bridge",
  "description": "Send VS Code file and selection references to Oh My Pi with Ctrl+Alt+K.",
  "version": "1.6.0",
  "publisher": "klondikemarlen",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/klondikemarlen/omp-vscode-context.git"
  },
  "homepage": "https://github.com/klondikemarlen/omp-vscode-context#readme",
  "bugs": {
    "url": "https://github.com/klondikemarlen/omp-vscode-context/issues"
  },
  "qna": false,
  "keywords": [
    "omp",
    "oh-my-pi",
    "vscode",
    "context",
    "selection",
    "ai",
    "agent",
    "coding-agent",
    "claude",
    "opencode"
  ],
  "engines": {
    "vscode": "^1.94.0"
  },
  "extensionKind": [
    "workspace"
  ],
  "categories": [
    "Machine Learning",
    "Other"
  ],
  "activationEvents": [
    "onCommand:ompContext.insertEditorContext",
    "onCommand:ompContext.insertAgentHandoff"
  ],
  "main": "./dist/extension.cjs",
  "files": [
    "dist",
    "omp",
    "README.md",
    "CONCEPTS.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "omp": {
    "extensions": [
      "./omp/index.js"
    ]
  },
  "contributes": {
    "commands": [
      {
        "command": "ompContext.insertEditorContext",
        "title": "OMP Context: Insert Editor Context"
      },
      {
        "command": "ompContext.insertAgentHandoff",
        "title": "OMP Context: Insert Agent Handoff Packet"
      }
    ],
    "keybindings": [
      {
        "command": "ompContext.insertEditorContext",
        "key": "cmd+alt+k",
        "mac": "cmd+alt+k",
        "win": "ctrl+alt+k",
        "linux": "ctrl+alt+k",
        "when": "editorTextFocus"
      }
    ],
    "configuration": {
      "title": "OMP VS Code Context",
      "properties": {
        "ompContext.endpoint": {
          "type": "string",
          "default": "",
          "description": "Override the OMP context bridge endpoint. Empty means read ~/.omp/agent/editor-context-bridge.json, then fall back to http://127.0.0.1:47687."
        },
        "ompContext.contentMode": {
          "type": "string",
          "enum": [
            "reference",
            "inline"
          ],
          "default": "inline",
          "description": "What Ctrl+Alt+K inserts for a selection. Inline includes the reference plus selected text as a fenced code block; reference sends only @file#Lx-Ly so OMP can read the file."
        },
        "ompContext.handoffPreface": {
          "type": "string",
          "default": "Goal:\n\nConstraints:\n\nVerify with:",
          "description": "Editable starter text included in OMP Context: Insert Agent Handoff Packet."
        },
        "ompContext.handoffMaxBytes": {
          "type": "number",
          "default": 20000,
          "minimum": 1000,
          "description": "Maximum bytes inserted by OMP Context: Insert Agent Handoff Packet."
        },
        "ompContext.handoffMaxDiagnostics": {
          "type": "number",
          "default": 20,
          "multipleOf": 1,
          "minimum": 0,
          "description": "Maximum VS Code diagnostics included in OMP Context: Insert Agent Handoff Packet."
        },
        "ompContext.handoffMaxVisibleEditors": {
          "type": "number",
          "default": 10,
          "multipleOf": 1,
          "minimum": 0,
          "description": "Maximum visible editor references included in OMP Context: Insert Agent Handoff Packet."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "check-types": "tsc --noEmit",
    "compile": "npm run check-types && node esbuild.js",
    "package": "npm run check-types && node esbuild.js --production",
    "package:vsix": "vsce package",
    "publish:marketplace": "vsce publish",
    "test": "npm run check-types && node --import tsx --test test/*.test.ts test/*.test.mjs"
  },
  "devDependencies": {
    "@types/node": "^20.14.12",
    "@types/vscode": "^1.94.0",
    "@vscode/vsce": "^3.9.2",
    "esbuild": "^0.25.3",
    "tsx": "^4.20.3",
    "typescript": "^5.8.3"
  }
}
